[Desktop Entry]
Type=Application
Name=Macqueen Desktop Portal
Exec=@MACQUEENDE_ROOT@/build/portal/bin/xdg-desktop-portal-macqueen --replace
X-KDE-Wayland-Interfaces=org_kde_kwin_fake_input,org_kde_plasma_window_management,zkde_screencast_unstable_v1
X-KDE-DBUS-Restricted-Interfaces=org.kde.KWin.ScreenShot2
NoDisplay=true
Icon=kde
