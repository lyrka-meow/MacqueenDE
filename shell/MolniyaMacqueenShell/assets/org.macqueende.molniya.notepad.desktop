[Desktop Entry]
Type=Application
Name=Molniya Notepad
GenericName=Text Editor
Comment=Quick notes and text files in MolniyaMacqueenShell
Exec=dms ipc call notepad openFile %f
Icon=danklogo
Terminal=false
NoDisplay=true
Categories=Utility;TextEditor;
