#!/usr/bin/env bash

set -euo pipefail

die()
{
    echo "start-macqueende: $*" >&2
    exit 1
}

resolve_repo_root()
{
    if [[ -n ${MACQUEENDE_ROOT:-} ]]; then
        printf '%s\n' "$MACQUEENDE_ROOT"
        return
    fi

    local script_dir
    script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
    if [[ -x "$script_dir/build/compositor/bin/macqueen" ]]; then
        printf '%s\n' "$script_dir"
        return
    fi

    if [[ -r /etc/macqueende/dev-root ]]; then
        IFS= read -r script_dir </etc/macqueende/dev-root
        printf '%s\n' "$script_dir"
        return
    fi

    die "cannot locate the MacqueenDE checkout; set MACQUEENDE_ROOT"
}

if [[ ${1:-} != "--inside-dbus" && -z ${DBUS_SESSION_BUS_ADDRESS:-} ]]; then
    command -v dbus-run-session >/dev/null ||
        die "dbus-run-session is required"
    exec dbus-run-session -- "$0" --inside-dbus
fi

repo_root=$(resolve_repo_root)
macqueen="$repo_root/build/compositor/bin/macqueen"
macqueen_screenshot_plugin="$repo_root/build/compositor/bin/kwin/plugins/screenshot.so"
macqueen_screenshot="$repo_root/build/macqueen-screenshot/bin/macqueen-screenshot"
molniya="$repo_root/session/run-molniya"
qml_module="$repo_root/build/quickshell-macqueen"
qt_plugins="$repo_root/build/compositor/bin:$repo_root/build/compositor/lib"

[[ -x "$macqueen" ]] ||
    die "missing $macqueen; build the compositor first"
[[ -f "$macqueen_screenshot_plugin" ]] ||
    die "missing $macqueen_screenshot_plugin; run: cmake --build $repo_root/build/compositor --target screenshot"
[[ -x "$macqueen_screenshot" ]] ||
    die "missing $macqueen_screenshot; build apps/macqueen-screenshot first"
[[ -x "$molniya" ]] ||
    die "missing $molniya"
[[ -f "$qml_module/Macqueen/Ipc/qmldir" ]] ||
    die "missing the Quickshell Macqueen module; build it first"
[[ -n ${XDG_RUNTIME_DIR:-} && -d ${XDG_RUNTIME_DIR:-} ]] ||
    die "XDG_RUNTIME_DIR is unavailable; start this from a real login TTY or SDDM"

export MACQUEENDE_ROOT="$repo_root"
export QT_PLUGIN_PATH="$qt_plugins${QT_PLUGIN_PATH:+:$QT_PLUGIN_PATH}"
export QML2_IMPORT_PATH="$qml_module${QML2_IMPORT_PATH:+:$QML2_IMPORT_PATH}"
export XDG_CURRENT_DESKTOP=MacqueenDE
export XDG_SESSION_DESKTOP=MacqueenDE
export XDG_SESSION_TYPE=wayland
export QT_QPA_PLATFORM=wayland
unset KDE_FULL_SESSION

if command -v dbus-update-activation-environment >/dev/null; then
    dbus-update-activation-environment --systemd \
        WAYLAND_DISPLAY \
        XDG_CURRENT_DESKTOP \
        XDG_SESSION_DESKTOP \
        XDG_SESSION_TYPE \
        QT_QPA_PLATFORM \
        2>/dev/null || true
fi

# A user systemd instance may survive logout from another desktop. Restart the
# broker after exporting MacqueenDE so it selects macqueende-portals.conf rather
# than keeping the previous desktop's portal backend.
if command -v systemctl >/dev/null; then
    systemctl --user restart xdg-desktop-portal.service 2>/dev/null || true
fi

exec "$macqueen" \
    --drm \
    --xwayland \
    --no-lockscreen \
    --no-kactivities \
    --exit-with-session "$molniya"
